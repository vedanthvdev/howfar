PORT=8787
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
# Comma-separated list of origins allowed to call this API. Always scope this
# in production — a wildcard exposes your API key's rate budget to any site
# the browser visits. For local Chrome extension testing use the extension
# origin, e.g.:
#   ALLOWED_ORIGINS=chrome-extension://abcdefghijklmnopqrstuvwxyz123456
ALLOWED_ORIGINS=chrome-extension://<YOUR_EXTENSION_ID>
# Cache TTL in seconds. Short-lived by design.
CACHE_TTL_SECONDS=900
# Max candidates accepted per /resolve-distances request.
MAX_CANDIDATES=20

# --- Free-tier safeguard ---------------------------------------------------
# Hard cap on estimated monthly Google Maps spend. When reached, the backend
# returns HTTP 429 `quota_exhausted` for all /resolve-* routes and the
# extension pauses scanning. Default is $180, leaving a ~$20 buffer under the
# $200 free credit.
BUDGET_MONTHLY_USD_CAP=180
# Estimated price per call, in USD. Update if Google changes list prices or
# your project has volume discounts. (Geocoding + Directions both default to
# $5 / 1,000 requests for the first 100k / month.)
BUDGET_PRICE_GEOCODE=0.005
BUDGET_PRICE_DIRECTIONS=0.005
# Where the monthly counter is persisted. Defaults to ./.budget.json next to
# the backend working directory.
# BUDGET_FILE=/absolute/path/to/.budget.json
# Admin token required to POST /budget/reset. If unset, the backend auto-
# generates one on first run (persisted alongside the counter) and, on
# localhost only, exposes it via GET /admin/token so the options page can
# pick it up. Set this explicitly in anything other than a dev machine.
# BUDGET_ADMIN_TOKEN=change-me-to-a-long-random-string
